{
  "name": "feishu-codex-bot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "type": "module",
  "engines": {
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts -- -c ./bot.config.json",
    "build": "tsc -p tsconfig.build.json",
    "build:bin": "bun build ./src/index.ts --compile --outfile ./dist-bun/feishu-codex-bot",
    "start": "bun ./dist/index.js -c ./bot.config.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "protocol:generate": "mkdir -p src/generated/codex-protocol && codex app-server generate-ts --out src/generated/codex-protocol"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "1.59.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "25.3.5",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.5.0",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
